-- Datos Enum de las entidades
CREATE TYPE tipo_rol AS ENUM ('admin', 'usuario');
CREATE TYPE tipo_estado_proyecto AS ENUM ('activo', 'archivado', 'cerrado');
CREATE TYPE tipo_estado_operativo AS ENUM ('activo', 'inactivo', 'eliminado');
CREATE TYPE tipo_categoria_hardware AS ENUM ('CPU', 'GPU', 'RAM', 'almacenamiento', 'Red');
CREATE TYPE tipo_origen_hardware AS ENUM ('catalogo', 'custom');
CREATE TYPE tipo_estado_componente AS ENUM ('activo', 'obsoleto');
CREATE TYPE tipo_estado_plantilla AS ENUM ('activa', 'obsoleta');
CREATE TYPE tipo_refrigeracion AS ENUM ('aire', 'inmersion_liquida');
CREATE TYPE tipo_protocolo AS ENUM ('SNMP', 'modbus_TCP');
CREATE TYPE tipo_alerta AS ENUM ('informativa', 'advertencia', 'corte_seguridad');
CREATE TYPE tipo_criticidad AS ENUM ('bajo', 'medio', 'alto', 'critico');
CREATE TYPE tipo_sugerencia AS ENUM ('Hardware', 'Software', 'Horario');


CREATE TABLE Divisa_moneda (
	id_divisa SERIAL PRIMARY KEY,
	codigo_iso VARCHAR(3) NOT NULL,
	simbolo_divisa VARCHAR(5) NOT NULL,
	nombre_divisa VARCHAR(50) NOT NULL,
	tasa_conversion_base NUMERIC(18,6)
	);

CREATE TABLE Perfil_Usuario (
	id_usuario SERIAL PRIMARY KEY,
	nombre_usuario VARCHAR(50) NOT NULL,
	correo_electronica VARCHAR(100) UNIQUE NOT NULL,
	contrasena VARCHAR(30) NOT NULL,
	rol_sistema tipo_rol DEFAULT 'usuario' NOT NULL,
	limite_gasto_local NUMERIC(18,2),
	limite_carbono_local NUMERIC(18,4) 
	);

CREATE TABLE Configuracion_parametros (
	id_parametros SERIAL PRIMARY KEY,
	id_usuario INTEGER NOT NULL,
	umbral_verde_porcentaje NUMERIC(5, 2) NOT NULL,
	umbral_amarillo_porcentaje NUMERIC(5, 2) NOT NULL,
	umbral_rojo_porcentaje NUMERIC(5, 2) NOT NULL,

	CONSTRAINT FK_configuracion_usuario FOREIGN KEY (id_usuario) REFERENCES Perfil_Usuario (id_usuario)
);

CREATE TABLE proyecto (
    id_proyecto SERIAL PRIMARY KEY,
    id_usuario INTEGER NOT NULL,
    id_divisa INTEGER NOT NULL,
    nombre_proyecto VARCHAR(150) NOT NULL,
    justificacion_base TEXT DEFAULT NULL,
    estado_proyecto tipo_estado_proyecto NOT NULL DEFAULT 'activo',
    presupuesto_eco_mensual NUMERIC(18, 2) DEFAUlT NULL,
    limite_carbono_mensual NUMERIC(18, 4) DEFAULT NULL,
    fecha_creacion TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
	CONSTRAINT FK_proyecto_usuario FOREIGN KEY (id_usuario) REFERENCES Perfil_Usuario (id_usuario),
    CONSTRAINT FK_proyecto_divisa FOREIGN KEY (id_divisa) REFERENCES divisa_moneda (id_divisa)
);


CREATE TABLE region_geografica (
    id_region SERIAL PRIMARY KEY,
	id_proveedor INTEGER NOT NULL,
    nombre_region VARCHAR(100) UNIQUE NOT NULL,
	proveedor_cloud VARCHAR (100) DEFAULT NULL,
	entorno_ejecucion VARCHAR(100) DEFAULT NULL,
	pue_promedio VARCHAR(100) DEFAULT NULL,
	nivel_dano_ambiental VARCHAR(100) DEFAULT NULL,
    factor_emision_gCO2eq NUMERIC(10, 4) NOT NULL,
    indice_wsi NUMERIC(8, 4) NOT NULL,
    es_renovable BOOLEAN NOT NULL DEFAULT FALSE,
    fecha_actualizacion_factor DATE NOT NULL
);


CREATE TABLE instancia_cloud (
    id_instancia SERIAL PRIMARY KEY,
    id_region INTEGER NOT NULL,
    nombre_instancia VARCHAR(100) NOT NULL,
	proveedor_cloud VARCHAR(100) NOT NULL,
    costo_por_hora_usd NUMERIC(12, 6) NOT NULL,
    consumo_promedio_watts NUMERIC(10, 4) NOT NULL,
    fecha_sincronizacion TIMESTAMP NOT NULL,
 
    CONSTRAINT UQ_inst_nombre_prov UNIQUE (nombre_instancia, proveedor_cloud),
    CONSTRAINT FK_instancia_region FOREIGN KEY (id_region) REFERENCES region_geografica (id_region)
);

CREATE TABLE intensidad_carbono_horaria (
    id_intensidad SERIAL PRIMARY KEY,
    id_region INTEGER NOT NULL,
    hora_dia SMALLINT NOT NULL,
    intensidad_gCO2eq NUMERIC(10, 4) CHECK(hora_dia BETWEEN 0 AND 23) NOT NULL,
 
    CONSTRAINT UQ_region_hora UNIQUE (id_region, hora_dia),
    CONSTRAINT FK_intensidad_region FOREIGN KEY (id_region) REFERENCES region_geografica (id_region)
);


CREATE TABLE matriz_energetica_local (
    id_matriz SERIAL PRIMARY KEY,
    nombre_instalacion VARCHAR(150) UNIQUE NOT NULL,
    pue_oficial NUMERIC(6, 4) NOT NULL,
    wue_oficial NUMERIC(6, 4) NOT NULL,
    tecnica_refrigeracion tipo_refrigeracion DEFAULT 'aire' NOT NULL,
    lectura_flujometro_manual NUMERIC(10, 4) DEFAULT NULL 
);

CREATE TABLE Fuente_emision (
	id_fuente SERIAL PRIMARY KEY,
	tipo_fuente VARCHAR(100) UNIQUE NOT NULL,
	es_renovable BOOLEAN NOT NULL,
	factor_estandar_gCO2eq NUMERIC(10,4) NOT NULL,
	fecha_ultima_actualizacion DATE NOT NULL
);

CREATE TABLE composicion_matriz (
    id_matriz INTEGER NOT NULL,
    id_fuente INTEGER NOT NULL,
    porcentaje_uso NUMERIC(5, 2) NOT NULL CHECK (porcentaje_uso BETWEEN 0 AND 100),
 
    PRIMARY KEY (id_matriz, id_fuente),
    CONSTRAINT FK_comp_matriz FOREIGN KEY (id_matriz) REFERENCES matriz_energetica_local (id_matriz),
    CONSTRAINT FK_comp_fuente FOREIGN KEY (id_fuente) REFERENCES fuente_emision (id_fuente)
);


CREATE TABLE Componente_hardware (
	id_componente SERIAL PRIMARY KEY,
	id_componente_sucesor INTEGER DEFAULT NULL,
	etiqueta_hardware VARCHAR(100) NOT NULL,
	fabricante VARCHAR(100) DEFAULT NULL,
	modelo_hw VARCHAR(100) DEFAULT NULL,
	arquitectura_anio VARCHAR(100) DEFAULT NULL,
	vram_gb VARCHAR(50) DEFAULT NULL,
	ancho_banda_gbs VARCHAR(50) DEFAULT NULL,
	fp16_fp32_tflops VARCHAR(50) DEFAULT NULL,
	eficiencia_tokens_watt VARCHAR(50) DEFAULT NULL,
	huella_co2e_kg VARCHAR(50) DEFAULT NULL,
	categoria_hardware tipo_categoria_hardware NOT NULL,
	TDP_estandar_watts NUMERIC(8, 2) NOT NULL,
	costo_unitario NUMERIC(12, 2)NOT NULL,
	tipo_origen tipo_origen_hardware NOT NULL DEFAULT 'catalogo',
	estado_componente tipo_estado_componente NOT NULL DEFAULT 'activo',
	ES_hardware_procesador BOOLEAN DEFAULT NULL,
	hardware_procesador INTEGER DEFAULT NULL,
	ES_hardware_memoria BOOLEAN DEFAULT NULL,
	hardware_memoria NUMERIC(8, 2) DEFAULT NULL
);

CREATE TABLE Plantilla_hardware (
	id_plantilla SERIAL PRIMARY KEY,
	id_usuario INTEGER NOT NULL,
	nombre_plantilla VARCHAR(150) NOT NULL,
	estado_plantilla tipo_estado_plantilla NOT NULL DEFAULT 'activa',
	fecha_creacion TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
	
	CONSTRAINT FK_plantilla_usuario FOREIGN KEY (id_usuario) REFERENCES Perfil_Usuario (id_usuario)
);


CREATE TABLE detalle_plantilla (
	id_plantilla INTEGER NOT NULL,
	id_componente INTEGER NOT NULL,
	cantidad_plantilla INTEGER NOT NULL CHECK (cantidad_plantilla > 0),
	
	PRIMARY KEY (id_plantilla, id_componente),
	CONSTRAINT fk_dp_plantilla FOREIGN KEY (id_plantilla)REFERENCES plantilla_hardware (id_plantilla),
    CONSTRAINT fk_dp_componente FOREIGN KEY (id_componente)REFERENCES componente_hardware (id_componente)
);




CREATE TABLE sensor_onpremise (
    id_sensor SERIAL PRIMARY KEY,
    direccion_ip VARCHAR(45) UNIQUE NOT NULL,
    protocolo_conexion tipo_protocolo NOT NULL,
    puerto INTEGER CHECK (puerto BETWEEN 1 AND 65535) NOT NULL,
    ubicacion_fisica VARCHAR(200) DEFAULT NULL
);

CREATE TABLE modelo (
    id_modelo SERIAL PRIMARY KEY,
    id_proyecto INTEGER NOT NULL,
    id_plantilla INTEGER DEFAULT NULL,
    id_region INTEGER DEFAULT NULL,
    id_matriz INTEGER DEFAULT NULL,
	id_instancia INTEGER DEFAULT NULL,
	id_sensor INTEGER DEFAULT NULL,
    nombre_modelo VARCHAR(150) NOT NULL,
    empresa_creador VARCHAR(100) DEFAULT NULL,
    parametros_billones VARCHAR(50) DEFAULT NULL,
    vram_minima_gb_fp16_int8 VARCHAR(50) DEFAULT NULL,
    consumo_energetico_base VARCHAR(50) DEFAULT NULL,
    unidad_medida VARCHAR(50) DEFAULT NULL,
    multiplicador_razonamiento VARCHAR(50) DEFAULT NULL,
    descripcion_contexto TEXT DEFAULT NULL,
    estado_operativo tipo_estado_operativo DEFAULT 'activo' NOT NULL,
    green_score NUMERIC(5, 2) DEFAULT NULL,
    es_cloud BOOLEAN NOT NULL DEFAULT FALSE,
    usa_generador_respaldo BOOLEAN NOT NULL DEFAULT FALSE,
    costo_predecido_ia NUMERIC(18, 2) DEFAULT NULL,
    duracion_predecida_ia BIGINT DEFAULT NULL,
 
    CONSTRAINT FK_modelo_proyecto FOREIGN KEY (id_proyecto) REFERENCES proyecto (id_proyecto),
    CONSTRAINT FK_modelo_plantilla FOREIGN KEY (id_plantilla) REFERENCES plantilla_hardware (id_plantilla),
    CONSTRAINT FK_modelo_region FOREIGN KEY (id_region) REFERENCES region_geografica (id_region),
    CONSTRAINT FK_modelo_matriz FOREIGN KEY (id_matriz) REFERENCES matriz_energetica_local (id_matriz),
	CONSTRAINT FK_modelo_instancia FOREIGN KEY (id_instancia) REFERENCES instancia_cloud (id_instancia),
	CONSTRAINT FK_modelo_sensor FOREIGN KEY (id_sensor) REFERENCES sensor_onpremise (id_sensor)
);

CREATE TABLE composicion_modelo (
    id_modelo INTEGER  NOT NULL,
    id_componente INTEGER  NOT NULL,
    cantidad INTEGER CHECK (cantidad > 0) NOT NULL,

    PRIMARY KEY (id_modelo, id_componente),
    CONSTRAINT FK_composicionM_modelo FOREIGN KEY (id_modelo) REFERENCES modelo (id_modelo),
    CONSTRAINT FK_composicionM_componente FOREIGN KEY (id_componente) REFERENCES componente_hardware (id_componente)
);



CREATE TABLE historial_ejecucion(
    id_ejecucion SERIAL PRIMARY KEY,
    id_modelo INTEGER NOT NULL,
    fecha_hora_ejecucion TIMESTAMP NOT NULL,
    costo_calculado_usd NUMERIC(18, 4) DEFAULT NULL,
    emision_calculada_gCO2eq NUMERIC(18, 4) DEFAULT NULL,
    consumo_calculado_kwh NUMERIC(18, 6) DEFAULT NULL,
    volumen_agua_estimado_lts NUMERIC(18, 4) DEFAULT NULL,
    tiempo_ejecucion_ms BIGINT DEFAULT NULL,
 
    CONSTRAINT FK_historial_modelo FOREIGN KEY (id_modelo) REFERENCES modelo (id_modelo)
);

CREATE TABLE log_excepcion (
    id_log SERIAL PRIMARY KEY,
	id_ejecucion INTEGER NOT NULL,
    codigo_error VARCHAR(50) NOT NULL,
    descripcion_falla TEXT NOT NULL,
    fecha_incidente TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,

    CONSTRAINT fk_log_historial FOREIGN KEY (id_ejecucion) REFERENCES historial_ejecucion (id_ejecucion)
);




CREATE TABLE lectura_telemetria (
    id_lectura SERIAL PRIMARY KEY,
    id_sensor INTEGER NOT NULL,
    id_modelo INTEGER NOT NULL,
    consumo_watts_registrado NUMERIC(10, 4) NOT NULL,
    marca_tiempo TIMESTAMP NOT NULL,

    CONSTRAINT FK_lectura_sensor FOREIGN KEY (id_sensor) REFERENCES sensor_onpremise (id_sensor),
    CONSTRAINT FK_lectura_modelo FOREIGN KEY (id_modelo) REFERENCES modelo (id_modelo)
);



CREATE TABLE recomendacion (
    id_recomendacion SERIAL PRIMARY KEY,
    id_modelo INTEGER NOT NULL,
    tipo_sugerencia tipo_sugerencia NOT NULL,
    mensaje_recomendacion TEXT NOT NULL,
    estado_silenciado BOOLEAN NOT NULL DEFAULT FALSE,
 
    CONSTRAINT FK_rec_modelo FOREIGN KEY (id_modelo) REFERENCES modelo (id_modelo)
);


CREATE TABLE registro_alerta (
    id_alerta SERIAL PRIMARY KEY,
    id_proyecto INTEGER DEFAULT NULL,
    id_modelo INTEGER DEFAULT NULL,
    tipo_alerta tipo_alerta NOT NULL,
    mensaje_contexto TEXT NOT NULL,
    fecha_emision TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    nivel_criticidad tipo_criticidad NOT NULL,
    leido BOOLEAN NOT NULL DEFAULT FALSE,
 
    CONSTRAINT FK_alert_proyecto FOREIGN KEY (id_proyecto) REFERENCES proyecto (id_proyecto),
    CONSTRAINT FK_alert_modelo FOREIGN KEY (id_modelo) REFERENCES modelo (id_modelo)
);

--ALTER TABLE

ALTER TABLE componente_hardware
    ADD CONSTRAINT FK_comp_sucesor FOREIGN KEY (id_componente_sucesor) REFERENCES componente_hardware (id_componente);
 
CREATE INDEX idx_comp_sucesor ON componente_hardware (id_componente_sucesor)
    WHERE id_componente_sucesor IS NOT NULL;
